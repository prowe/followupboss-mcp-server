# Your Follow Up Boss API Key
# Get it from: FUB Settings > API > Copy your API key
FUB_API_KEY=your_api_key_here

# Safe Mode (recommended) -- disables all delete tools
# Set to "true" to enable, "false" for full access
FUB_SAFE_MODE=true

# ============================================================================
# OPTIONAL: Registered-Third-Party-System credentials
# ============================================================================
#
# !!! READ THE WARNING IN README.md BEFORE UNCOMMENTING THESE !!!
#
# These credentials are issued by Follow Up Boss to APPROVED third-party
# integration partners (developers who have registered a real app with FUB).
# They unlock the following "Restricted - Registered Systems Only" endpoints:
#
#   - Webhooks (list/create/get/update/delete)
#   - Inbox app installations, messages, notes, conversations, participants
#   - Automations 2.0 (list/get + people management)
#   - Text-message logging  (note: this is LOG-ONLY; FUB does NOT send SMS)
#   - Person attachments + Deal attachments (externally hosted URIs only)
#
# Using credentials you did NOT receive directly from FUB to access these
# endpoints may violate FUB's Terms of Service and risk account suspension.
# See: https://docs.followupboss.com/reference#identification
#
# If you do not have your OWN legitimate registered-system credentials,
# LEAVE THESE LINES COMMENTED OUT. The 130+ unrestricted tools all work
# fine on a regular FUB API key. The restricted tools will fail with a
# clear "requires X-System..." error message — by design.
#
# FUB_SYSTEM=YourRegisteredSystemName
# FUB_SYSTEM_KEY=your_registered_system_key_here
