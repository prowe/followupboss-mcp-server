# Your Follow Up Boss API Key
# Get it from: FUB Settings > API > Copy your API key
FUB_API_KEY=your_api_key_here

# Safe Mode (recommended) -- disables all delete tools
# Set to "true" to enable, "false" for full access
FUB_SAFE_MODE=true

# Optional: Required ONLY for webhook tools (listWebhooks, createWebhook, etc.)
# FUB rejects webhook calls without X-System + X-System-Key headers.
# Get these by registering as a third-party system with FUB:
# https://docs.followupboss.com/docs/embedded-apps#registering-your-application
# FUB_SYSTEM=YourRegisteredSystemName
# FUB_SYSTEM_KEY=your_system_key_here
